MUSIMACK_APPLICATION_NAME="Musimack SEO Toolkit"
MUSIMACK_ENVIRONMENT="development"
MUSIMACK_LOG_LEVEL="INFO"
MUSIMACK_CRAWLER_USER_AGENT="MusimackSEOToolkit/0.1"
MUSIMACK_DEFAULT_MAXIMUM_URLS=5000
MUSIMACK_DEFAULT_MAXIMUM_CRAWL_DEPTH=10
MUSIMACK_DEFAULT_REQUEST_TIMEOUT_SECONDS=20
MUSIMACK_DEFAULT_PER_HOST_CONCURRENCY=2
MUSIMACK_DEFAULT_GLOBAL_CRAWL_CONCURRENCY=4
MUSIMACK_DEFAULT_MINIMUM_REQUEST_DELAY_SECONDS=0.5
MUSIMACK_INCLUDE_SUBDOMAINS_BY_DEFAULT=false
MUSIMACK_FETCH_MAXIMUM_REDIRECT_HOPS=10
MUSIMACK_FETCH_MAXIMUM_RESPONSE_BODY_BYTES=5000000
MUSIMACK_FETCH_MAXIMUM_RESPONSE_HEADER_BYTES=65536
MUSIMACK_FETCH_MAXIMUM_DNS_ANSWERS=16
MUSIMACK_FETCH_CONNECT_TIMEOUT_SECONDS=10
MUSIMACK_FETCH_READ_TIMEOUT_SECONDS=20
MUSIMACK_FETCH_WRITE_TIMEOUT_SECONDS=10
MUSIMACK_FETCH_POOL_TIMEOUT_SECONDS=10
MUSIMACK_FETCH_TOTAL_REQUEST_DEADLINE_SECONDS=30
MUSIMACK_FETCH_RETRY_COUNT=1
MUSIMACK_FETCH_PERMITTED_PRODUCTION_PORTS=[80,443]
MUSIMACK_FETCH_HTTP_ALLOWED=true
MUSIMACK_FETCH_HTTPS_ALLOWED=true
MUSIMACK_FETCH_TRUST_ENVIRONMENT_PROXIES=false
