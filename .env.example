MUSIMACK_APPLICATION_NAME="Musimack SEO Toolkit"
MUSIMACK_ENVIRONMENT="development"
MUSIMACK_LOG_LEVEL="INFO"
MUSIMACK_CRAWLER_USER_AGENT="MusimackSEOToolkit/0.1"
MUSIMACK_DEFAULT_MAXIMUM_URLS=5000
MUSIMACK_DEFAULT_MAXIMUM_CRAWL_DEPTH=10
MUSIMACK_DEFAULT_REQUEST_TIMEOUT_SECONDS=20
MUSIMACK_DEFAULT_PER_HOST_CONCURRENCY=2
MUSIMACK_DEFAULT_GLOBAL_CRAWL_CONCURRENCY=4
MUSIMACK_DEFAULT_MINIMUM_REQUEST_DELAY_SECONDS=0.5
MUSIMACK_INCLUDE_SUBDOMAINS_BY_DEFAULT=false
