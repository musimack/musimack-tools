# Frontend values are public browser configuration, never secrets.
VITE_API_BASE_URL=/api/internal/v1
VITE_APP_NAME="Musimack SEO Toolkit"
VITE_FRONTEND_VERSION=seo-toolkit-frontend-foundation-v1
VITE_REQUEST_TIMEOUT_MS=10000
VITE_ENABLE_DEV_DIAGNOSTICS=false
VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:8000
# Phase 19 polling intervals are fixed, bounded application behavior rather than environment input.
# Browser configuration must never contain credentials, publication roots, or artifact paths.
# Phase 20 metadata audits are opt-in and require durable Phase 20A page evidence.
MUSIMACK_PERSISTENCE_METADATA_AUDIT_ENABLED=false
MUSIMACK_PERSISTENCE_METADATA_AUDIT_TITLE_SHORT_THRESHOLD=20
MUSIMACK_PERSISTENCE_METADATA_AUDIT_TITLE_LONG_THRESHOLD=60
MUSIMACK_PERSISTENCE_METADATA_AUDIT_DESCRIPTION_SHORT_THRESHOLD=70
MUSIMACK_PERSISTENCE_METADATA_AUDIT_DESCRIPTION_LONG_THRESHOLD=160
MUSIMACK_PERSISTENCE_METADATA_AUDIT_BATCH_SIZE=250
MUSIMACK_PERSISTENCE_METADATA_AUDIT_DEFAULT_PAGE_SIZE=50
MUSIMACK_PERSISTENCE_METADATA_AUDIT_MAX_PAGE_SIZE=200
MUSIMACK_PERSISTENCE_METADATA_AUDIT_MAX_PAGES=100000
MUSIMACK_PERSISTENCE_METADATA_AUDIT_MAX_ISSUES_PER_PAGE=100
MUSIMACK_PERSISTENCE_METADATA_AUDIT_MAX_EXPORT_ROWS=100000
MUSIMACK_PERSISTENCE_METADATA_AUDIT_DUPLICATE_SAMPLE_SIZE=20
